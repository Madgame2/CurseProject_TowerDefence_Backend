{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "CommonJS",
    "target": "ES2020",

    "types": ["node"],

    "esModuleInterop": true,

    "sourceMap": true,

    "strict": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "skipLibCheck": true

  },
  "exclude": ["prisma.config.ts", "node_modules"]
}
